# apply SPA — client env (Vite injects VITE_* at build).
# INV-5: ONLY the Supabase anon key belongs in a VITE_* var — service_role is
# server-only and must NEVER appear here or in this client bundle.
# Canonical registry: TECH_STACK.md §5.6.
VITE_SUPABASE_URL=https://kgyzptpzccoczbruhvow.supabase.co
VITE_SUPABASE_ANON_KEY=<the gt-apply-demo anon key>

# Optional link target for the demo "pages dropbox" cockpit quick-jump.
VITE_COCKPIT_URL=#cockpit

# Demo-only (synthetic, INV-1). Emitted by backend/scripts/seed_demo_supabase.py.
# Unset ⇒ the family-switcher renders its honest "no seeded families" state.
#   VITE_DEMO_FAMILIES : JSON array  [{ "uid","familyId","label","hint" }, ...]
#   VITE_DEMO_SESSIONS : JSON object { "<uid>": { "access_token","refresh_token" } }
#     (per-family seeded ANON-session tokens, restored via auth.setSession. Anon-only.)
VITE_DEMO_FAMILIES=
VITE_DEMO_SESSIONS=
