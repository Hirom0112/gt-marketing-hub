# frontend/.env.example — front-end build-time env (placeholder only).
#
# The canonical env-var registry is TECH_STACK.md §5 (single source of
# truth). This file lists ONLY the vars the React build reads; do not
# duplicate backend vars here. No real secrets or production PII (CLAUDE
# INV-1). Copy to `frontend/.env` and adjust locally.

# Base URL the React app calls. Mirrors GT_API_BASE_URL (TECH_STACK §5.1),
# injected into the client at build time via Vite's VITE_ prefix.
VITE_GT_API_BASE_URL=http://localhost:8000
