# .env.example — mirrors the canonical env-var registry in TECH_STACK.md §5.
# PLACEHOLDER VALUES ONLY. No real secrets or production PII ever land here
# (CLAUDE.md INV-1; TECH_STACK.md §5). Copy to `.env` and fill locally.
# TECH_STACK.md §5 is the single source of truth — add new vars THERE, not here.

# --- §5.1 Core / runtime ---------------------------------------------------
GT_ENV=development
GT_LOG_LEVEL=INFO
GT_API_BASE_URL=http://localhost:8000
GT_CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# --- §5.2 Supabase / Postgres (D-2) ----------------------------------------
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<public anon key>
# Server-side only — never shipped to the client.
SUPABASE_SERVICE_ROLE_KEY=<secret>
DATABASE_URL=postgres://user:password@localhost:5432/gtschool

# --- §5.3 Anthropic Claude API (D-5, §6.1) ---------------------------------
ANTHROPIC_API_KEY=<secret>
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-8
ANTHROPIC_MODEL_FAST=claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=16000
# Hard per-run token ceiling; exceeding trips the kill switch (NFR-5).
LLM_RUN_TOKEN_CAP=200000
# When true, all live LLM calls are disabled → deterministic/placeholder mode.
LLM_KILL_SWITCH=false

# --- §5.4 Simulated external integrations (v1 = no live calls) --------------
HUBSPOT_PRIVATE_APP_TOKEN=<placeholder>
SEND_MODE=simulate
MEDIA_GEN_MODE=placeholder
SOCIAL_POST_MODE=simulate

# --- §5.5 Cost / kill-switch controls (NFR-5) ------------------------------
COST_DAILY_USD_CAP=25.00
COST_ALERT_USD_THRESHOLD=15.00
